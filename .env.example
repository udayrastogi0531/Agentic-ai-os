# ============================================
# Uday AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=Uday AI
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://udayai:udayai_password@localhost:5432/udayai_db
POSTGRES_USER=udayai
POSTGRES_PASSWORD=udayai_password
POSTGRES_DB=udayai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chromadb

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM Providers ---
# Ollama (Local - Default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# OpenAI (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Optional)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (Optional)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-specdec
GROQ_CODING_MODEL=deepseek-r1-distill-llama-70b

# Default LLM Provider: ollama | openai | gemini | groq
DEFAULT_LLM_PROVIDER=ollama

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Voice ---
WHISPER_MODEL=base
PIPER_MODEL_PATH=./models/piper/en_US-lessac-medium.onnx
WAKE_WORD_MODEL=hey_uday
ASSISTANT_VOICE_PROFILE=Nidhi # Default assistant profile. Options: Nidhi | Uday AI

# --- Web Search ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# --- Google APIs (Calendar & Gmail) ---
# Note: Client credentials are required to authorize Gmail and Calendar MCP servers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- GitHub ---
GITHUB_TOKEN=

# --- MCP Servers ---
MCP_FILESYSTEM_ENABLED=true
MCP_FILESYSTEM_ROOT=./workspace
MCP_BROWSER_ENABLED=true
BROWSERLESS_URL=ws://localhost:3000
MCP_GMAIL_ENABLED=false
MCP_CALENDAR_ENABLED=false
MCP_GITHUB_ENABLED=false

# --- NextAuth (Frontend) ---
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./data/uploads

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/udayai.log
